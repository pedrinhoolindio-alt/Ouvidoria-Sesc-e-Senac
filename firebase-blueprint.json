{
  "entities": {
    "Protocolo": {
      "title": "Protocolo",
      "description": "Dados de um protocolo de ouvidoria",
      "type": "object",
      "properties": {
        "Número Sequencial": {
          "type": "string",
          "description": "Número do protocolo"
        },
        "Data de Submissão": {
          "type": "string",
          "description": "Data em que o protocolo foi submetido"
        },
        "Status": {
          "type": "string",
          "description": "Status atual do protocolo"
        },
        "Tipo": {
          "type": "string",
          "description": "Tipo de demanda"
        },
        "Localidade": {
          "type": "string",
          "description": "Localidade da ocorrência"
        }
      },
      "required": ["Número Sequencial", "Data de Submissão", "Status"]
    },
    "Configuracoes": {
      "title": "Configurações",
      "description": "Configurações visuais do sistema",
      "type": "object",
      "properties": {
        "loginBg": {
          "type": "string",
          "description": "URL da imagem de fundo do login"
        },
        "loginBgMobile": {
          "type": "string",
          "description": "URL da imagem de fundo do login para celular"
        },
        "logoUrl": {
          "type": "string",
          "description": "URL da logomarca"
        }
      }
    }
  },
  "firestore": {
    "/protocolos_sesc/{id}": {
      "schema": "Protocolo",
      "description": "Protocolos da unidade Sesc"
    },
    "/protocolos_senac/{id}": {
      "schema": "Protocolo",
      "description": "Protocolos da unidade Senac"
    },
    "/settings/{id}": {
      "schema": "Configuracoes",
      "description": "Configurações globais do sistema"
    }
  }
}
