// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: protocolos_sesc, protocolos_senac
// Document ID: auto-generated
// Fields:
//   - Número Sequencial: string (required) - Protocol number
//   - Data de Realização: string (required) - Date of realization
//   - Status: string (required) - Current status
//   - Tipo: string (optional) - Type of demand
//   - Localidade: string (optional) - Location
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "phenrique@sesc-ce.com.br" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidProtocol(data) {
      return data['Número Sequencial'] is string && data['Número Sequencial'].size() < 100 &&
             data['Data de Realização'] is string && data['Data de Realização'].size() < 50 &&
             data['Status'] is string && data['Status'].size() < 100 &&
             (!('Tipo' in data) || (data['Tipo'] is string && data['Tipo'].size() < 200)) &&
             (!('Localidade' in data) || (data['Localidade'] is string && data['Localidade'].size() < 200));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /protocolos_sesc/{protocolId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProtocol(request.resource.data);
      allow update: if isAuthenticated() && isValidProtocol(request.resource.data);
      allow delete: if isAdmin();
    }

    match /protocolos_senac/{protocolId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProtocol(request.resource.data);
      allow update: if isAuthenticated() && isValidProtocol(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
